  <Requirements:Requirement xmi:id="_sbcdYHCSEfGBCven3WVkOQ" base_NamedElement="_saFLcHCSEfGBCven3WVkOQ" id="SYS-000" text="The Water Subsystem shall provide water storage, distribution, monitoring and control functions required for safe and continuous rail grinding operations.&#xD;&#xA;" base_Class="_saFLcHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_3V0gQHCSEfGBCven3WVkOQ" base_NamedElement="_3VuZoHCSEfGBCven3WVkOQ" id="SYS-001" text="The Water Subsystem shall store a minimum of 6000 litres of water for grinding operations." base_Class="_3VuZoHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_318KwHCSEfGBCven3WVkOQ" base_NamedElement="_312rMHCSEfGBCven3WVkOQ" id="SYS-002" text="The Water Subsystem shall supply water to the grinding unit at the required flow rate during normal operations." base_Class="_312rMHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_4QMd0HCSEfGBCven3WVkOQ" base_NamedElement="_4QHlUHCSEfGBCven3WVkOQ" id="SYS-003" text="The Water Subsystem shall activate hazard suppression water supply upon detection of a fire or heat event." base_Class="_4QHlUHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_4d4UgHCSEfGBCven3WVkOQ" base_NamedElement="_4d0DEHCSEfGBCven3WVkOQ" id="SYS-004" text="The Water Subsystem shall supply hazard suppression water at a minimum flow rate of 60 litres per minute through at least one water cannon with a minimum reach of 20 metres." base_Class="_4d0DEHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_4pvmQHCSEfGBCven3WVkOQ" base_NamedElement="_4pr74HCSEfGBCven3WVkOQ" id="SYS-005" text="The Water Subsystem shall provide a 60m hose nozzle and independently controlled sleeper and ditch spray nozzles for front and rear coverage." base_Class="_4pr74HCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_60auEHCSEfGBCven3WVkOQ" base_NamedElement="_60XDsHCSEfGBCven3WVkOQ" id="SYS-006" text="The Water Subsystem shall provide potable water supply to the crew at all times during operations." base_Class="_60XDsHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_7EE6sXCSEfGBCven3WVkOQ" base_NamedElement="_7EE6sHCSEfGBCven3WVkOQ" id="SYS-007" text="The Water Subsystem shall monitor tank water level and generate an alert when below minimum threshold." base_Class="_7EE6sHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_7QUm8HCSEfGBCven3WVkOQ" base_NamedElement="_7QQ8kHCSEfGBCven3WVkOQ" id="SYS-008" text="The Water Subsystem shall execute a full emergency shutdown of water flow within 5 seconds of trigger." base_Class="_7QQ8kHCSEfGBCven3WVkOQ"/>
  <Requirements:Requirement xmi:id="_7ehbAHCSEfGBCven3WVkOQ" base_NamedElement="_7eeXsHCSEfGBCven3WVkOQ" id="SYS-009" text="The Water Subsystem shall support external filling from a ground supply connection." base_Class="_7eeXsHCSEfGBCven3WVkOQ"/>
